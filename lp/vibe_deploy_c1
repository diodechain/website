    lastFocus=document.activeElement;
    modal.removeAttribute('hidden');
    modal.classList.add('is-open');
    document.body.style.overflow='hidden';
    if(heroVideo&&modalVideo){
      try{modalVideo.currentTime=heroVideo.currentTime;}catch(e){}
      heroVideo.pause();
    }
    modalVideo.play().catch(function(){});
    closeBtn.focus();
  }
  function closeModal(){
    modal.classList.remove('is-open');
    modal.setAttribute('hidden','');
    document.body.style.overflow='';
    modalVideo.pause();
    if(heroVideo){heroVideo.play().catch(function(){});}
    openEl.blur();
    if(lastFocus&&typeof lastFocus.focus==='function'&&lastFocus!==openEl&&!openEl.contains(lastFocus)){
      try{lastFocus.focus({focusVisible:false});}catch(_){lastFocus.focus();}
    }
    lastFocus=null;
  }
  openEl.addEventListener('click',function(e){e.preventDefault();openModal();});
  openEl.addEventListener('keydown',function(e){
    if(e.key==='Enter'||e.key===' '){e.preventDefault();openModal();}
  });
  closeBtn.addEventListener('click',function(e){e.stopPropagation();closeModal();});
  modal.addEventListener('click',function(e){if(e.target===modal)closeModal();});
  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'&&modal.classList.contains('is-open')){e.preventDefault();closeModal();}
  });
})();
</script>

